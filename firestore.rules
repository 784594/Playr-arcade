rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isTrustedOwner() {
      return signedIn() && request.auth.token.email == 'owner@playr.io';
    }

    function normalizedName(value) {
      return value.lower();
    }

    function hasReservedTerms(loweredName) {
      return loweredName.matches('.*(admin|administrator|moderator|mod|owner|staff|support|developer|dev|root|system|official|manager).*');
    }

    function hasProfanity(loweredName) {
      return loweredName.matches('.*(fuck|shit|bitch|asshole|bastard|dick|pussy|cunt|slut|whore|porn|sex|nude|nsfw|xxx|cock|fck|fcuk|shyt|btch|faggot|fag|nigga|nigger|retard|tranny|homo|daddy).*');
    }

    function hasObfuscatedProfanity(loweredName) {
      return loweredName.matches('.*[f][uuvv@4][c(kq)][kq].*')
        || loweredName.matches('.*[s5$][h#][i1!l|][t7+].*')
        || loweredName.matches('.*[b8][i1!l|][t7+][c(kq)][h#].*')
        || loweredName.matches('.*[a@4v][s5$z][s5$z][h#][o0][l1!i|][e3].*')
        || loweredName.matches('.*[p9][uuvv@4][s5$][s5$][yuv].*')
        || loweredName.matches('.*[c(kq)][uuvv@4][n][t7+].*')
        || loweredName.matches('.*[n][i1!l|][g9][g9][a@4uxv].*')
        || loweredName.matches('.*[n][i1!l|][g9][g9][e3][r].*')
        || loweredName.matches('.*[r][e3][t7+][a@4][r][db].*')
        || loweredName.matches('.*[db][a@4vux][db][db][yuv].*');
    }

    function validDisplayName(displayName) {
      return displayName is string
        && displayName.size() >= 3
        && displayName.size() <= 24
        && displayName.matches('^[A-Za-z0-9 _.\\-]{3,24}$')
        && !hasReservedTerms(normalizedName(displayName))
        && !hasProfanity(normalizedName(displayName))
        && !hasObfuscatedProfanity(normalizedName(displayName));
    }

    function validDisplayNameReservationDoc(normalized) {
      return request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.normalized is string
        && request.resource.data.normalized == normalized
        && request.resource.data.normalized == normalizedName(request.resource.data.displayName)
        && validDisplayName(request.resource.data.displayName)
        && request.resource.data.isAdmin == false;
    }

    function validUserProfileDoc(uid) {
      return request.resource.data.uid is string
        && request.resource.data.uid == uid
        && request.resource.data.displayName is string
        && request.resource.data.normalizedDisplayName is string
        && request.resource.data.normalizedDisplayName == normalizedName(request.resource.data.displayName)
        && validDisplayName(request.resource.data.displayName)
        && request.resource.data.isAdmin == false
        && (
          !('identifier' in request.resource.data)
          || request.resource.data.identifier == null
          || request.resource.data.identifier is string
        )
        && (
          !('identifierType' in request.resource.data)
          || request.resource.data.identifierType == null
          || request.resource.data.identifierType is string
        )
        && (
          !('roles' in request.resource.data)
          || request.resource.data.roles is list
        )
        && (
          !('isVip' in request.resource.data)
          || request.resource.data.isVip is bool
        )
        && (
          !('verified' in request.resource.data)
          || request.resource.data.verified == null
          || request.resource.data.verified is bool
          || request.resource.data.verified is map
        )
        && (
          !('signupCaptcha' in request.resource.data)
          || request.resource.data.signupCaptcha == null
          || request.resource.data.signupCaptcha is map
        )
        && (
          !('profileTheme' in request.resource.data)
          || request.resource.data.profileTheme == null
          || request.resource.data.profileTheme is map
        )
        && (
          !('progression' in request.resource.data)
          || request.resource.data.progression == null
          || request.resource.data.progression is map
        )
        && (
          !('progressionUpdatedAt' in request.resource.data)
          || request.resource.data.progressionUpdatedAt is number
        )
        && (
          !('staff' in request.resource.data)
          || request.resource.data.staff == null
          || request.resource.data.staff is map
        );
    }

    function hasRestrictedRoles(roleList) {
      return roleList is list && roleList.hasAny(['owner', 'admin', 'moderator', 'support']);
    }

    function roleRank(roleList) {
      return roleList is list
        ? (
            roleList.hasAny(['admin']) ? 3
            : roleList.hasAny(['moderator']) ? 2
            : roleList.hasAny(['support']) ? 1
            : 0
          )
        : 0;
    }

    function requesterRoleRank() {
      return isTrustedOwner()
        ? 4
        : (
            signedIn()
            && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
              ? roleRank(get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.roles)
              : 0
          );
    }

    function targetRoleRank() {
      return roleRank(resource.data.roles);
    }

    function requestedTargetRoleRank() {
      return roleRank(request.resource.data.roles);
    }

    function staffTargetAllowed() {
      return signedIn()
        && resource.data.uid != request.auth.uid
        && requesterRoleRank() > targetRoleRank();
    }

    function supportWarningOnlyUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return requesterRoleRank() == 1
        && staffTargetAllowed()
        && targetRoleRank() == 0
        && changed.hasOnly(['moderation', 'updatedAt'])
        && request.resource.data.roles == resource.data.roles
        && request.resource.data.moderation.warningCount >= resource.data.moderation.warningCount
        && request.resource.data.moderation.mutedUntil == resource.data.moderation.mutedUntil
        && request.resource.data.moderation.mutedPermanent == resource.data.moderation.mutedPermanent
        && request.resource.data.moderation.muteReason == resource.data.moderation.muteReason
        && request.resource.data.moderation.ban == resource.data.moderation.ban;
    }

    function moderatorModerationUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return requesterRoleRank() == 2
        && staffTargetAllowed()
        && changed.hasOnly(['moderation', 'updatedAt'])
        && request.resource.data.roles == resource.data.roles
        && request.resource.data.moderation.ban == resource.data.moderation.ban
        && !request.resource.data.moderation.mutedPermanent
        && request.resource.data.moderation.mutedUntil <= request.time.toMillis() + (24 * 60 * 60 * 1000);
    }

    function adminModerationUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return requesterRoleRank() == 3
        && staffTargetAllowed()
        && changed.hasOnly(['moderation', 'updatedAt'])
        && request.resource.data.roles == resource.data.roles
        && (
          !request.resource.data.moderation.ban.active
          || (
            !request.resource.data.moderation.ban.permanent
            && request.resource.data.moderation.ban.expiresAt <= request.time.toMillis() + (7 * 24 * 60 * 60 * 1000)
          )
        );
    }

    function staffRoleUpdateAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return staffTargetAllowed()
        && changed.hasOnly(['roles', 'staff', 'updatedAt'])
        && request.resource.data.moderation == resource.data.moderation
        && (
          (requesterRoleRank() == 2
            && targetRoleRank() <= 1
            && requestedTargetRoleRank() <= 1)
          || (requesterRoleRank() == 3
            && targetRoleRank() <= 2
            && requestedTargetRoleRank() <= 2)
        );
    }

    function selfProfileModerationUnchanged() {
      return !('moderation' in request.resource.data)
        || !('moderation' in resource.data)
        || request.resource.data.moderation == resource.data.moderation;
    }

    function selfProfileSignupCaptchaUnchanged() {
      return !('signupCaptcha' in request.resource.data)
        || !('signupCaptcha' in resource.data)
        || request.resource.data.signupCaptcha == resource.data.signupCaptcha;
    }

    function selfProfileRolesAllowed() {
      return !('roles' in request.resource.data)
        || (
          request.resource.data.roles is list
          && !hasRestrictedRoles(request.resource.data.roles)
        );
    }

    function selfProfileSignupCaptchaAbsentOnCreate() {
      return !('signupCaptcha' in request.resource.data)
        || request.resource.data.signupCaptcha == null;
    }

    function validFriendRequestDoc() {
      return request.resource.data.senderUid is string
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUid is string
        && request.resource.data.recipientUid != request.auth.uid
        && request.resource.data.senderName is string
        && request.resource.data.recipientName is string
        && validDisplayName(request.resource.data.senderName)
        && validDisplayName(request.resource.data.recipientName)
        && request.resource.data.status == 'pending';
    }

    function validFriendRequestUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.recipientUid == resource.data.recipientUid
        && request.resource.data.senderName == resource.data.senderName
        && request.resource.data.recipientName == resource.data.recipientName
        && changed.hasOnly(['status', 'updatedAt', 'respondedAt'])
        && (
          (resource.data.senderUid == request.auth.uid && request.resource.data.status == 'cancelled')
          || (
            resource.data.recipientUid == request.auth.uid
            && (
              request.resource.data.status == 'accepted'
              || request.resource.data.status == 'rejected'
            )
          )
        );
    }

    function validFriendshipDoc() {
      return request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants.hasAny([request.auth.uid])
        && request.resource.data.participantNames is map
        && request.resource.data.createdByUid is string
        && request.resource.data.createdByUid == request.auth.uid;
    }

    function validTttRoomId(roomId) {
      return roomId is string
        && roomId.matches('^ttt-[a-z0-9]{8,16}$');
    }

    function validCraftRoomId(roomId) {
      return roomId is string
        && (
          roomId.matches('^INF[A-Z0-9]{5,12}$')
          || roomId.matches('^inf-[a-z0-9]{4,16}$')
        );
    }

    function validBattleshipRoomId(roomId) {
      return roomId is string
        && roomId.matches('^bnf-[a-z0-9]{6,16}$');
    }

    function validConnect4RoomId(roomId) {
      return roomId is string
        && roomId.matches('^c4-[a-z0-9]{6,16}$');
    }

    function validChopsticksRoomId(roomId) {
      return roomId is string
        && roomId.matches('^chp-[a-z0-9]{6,16}$');
    }

    function validPresenceDoc() {
      return request.resource.data.keys().hasOnly(['uid', 'name', 'x', 'y', 'color', 'updatedAt', 'active'])
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 24
        && request.resource.data.x is number
        && request.resource.data.y is number
        && request.resource.data.color is string
        && request.resource.data.color.size() <= 16
        && request.resource.data.active is bool;
    }

    function validTttMessage() {
      return request.resource.data.keys().hasOnly(['authorUid', 'authorName', 'authorProfile', 'text', 'createdAt'])
        && request.resource.data.authorUid is string
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() >= 1
        && request.resource.data.authorName.size() <= 24
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 220
        && (
          request.resource.data.authorProfile == null
          || request.resource.data.authorProfile is map
        );
    }

    function validConnect4Message() {
      return request.resource.data.keys().hasOnly(['authorUid', 'authorName', 'authorProfile', 'text', 'createdAt'])
        && request.resource.data.authorUid is string
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() >= 1
        && request.resource.data.authorName.size() <= 24
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 220
        && (
          request.resource.data.authorProfile == null
          || request.resource.data.authorProfile is map
        );
    }

    function tttRoomFields() {
      return [
        'roomId',
        'status',
        'board',
        'turn',
        'winner',
        'xUid',
        'xName',
        'oUid',
        'oName',
        'hostUid',
        'hostName',
        'playerScores',
        'xScore',
        'oScore',
        'draws',
        'roundNumber',
        'scoreRound',
        'rematchVotes',
        'createdAt',
        'updatedAt',
        'adminLastOverrideAt',
        'adminLastOverrideBy',
        'moderation',
        'coinTossAt'
      ];
    }

    function validTttBoard(board) {
      return board is list
        && board.size() == 9
        && board[0] is string
        && board[1] is string
        && board[2] is string
        && board[3] is string
        && board[4] is string
        && board[5] is string
        && board[6] is string
        && board[7] is string
        && board[8] is string;
    }

    function validTttRoomCreate(roomId) {
      return request.resource.data.keys().hasOnly(tttRoomFields())
        && request.resource.data.roomId == roomId
        && request.resource.data.status == 'waiting'
        && validTttBoard(request.resource.data.board)
        && request.resource.data.turn == 'X'
        && request.resource.data.winner == ''
        && request.resource.data.xUid == request.auth.uid
        && request.resource.data.oUid == ''
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.xName is string
        && request.resource.data.hostName is string
        && request.resource.data.oName is string
        && request.resource.data.playerScores is map
        && request.resource.data.xScore is int
        && request.resource.data.oScore is int
        && request.resource.data.draws is int
        && request.resource.data.roundNumber is int
        && request.resource.data.scoreRound is int
        && request.resource.data.rematchVotes is map
        && request.resource.data.adminLastOverrideBy is string;
    }

    function tttIsCurrentPlayer() {
      return resource.data.xUid == request.auth.uid || resource.data.oUid == request.auth.uid;
    }

    function tttIsJoiningPlayer() {
      return !tttIsCurrentPlayer()
        && (
          (resource.data.xUid == '' && request.resource.data.xUid == request.auth.uid)
          || (resource.data.oUid == '' && request.resource.data.oUid == request.auth.uid)
        );
    }

    function validTttParticipantUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.keys().hasOnly(tttRoomFields())
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.createdAt == resource.data.createdAt
        && validTttBoard(request.resource.data.board)
        && request.resource.data.xUid == resource.data.xUid
        && request.resource.data.oUid == resource.data.oUid
        && request.resource.data.hostName == resource.data.hostName
        && changed.hasOnly([
          'status',
          'board',
          'turn',
          'winner',
          'xName',
          'oName',
          'playerScores',
          'xScore',
          'oScore',
          'draws',
          'roundNumber',
          'scoreRound',
          'rematchVotes',
          'updatedAt',
          'coinTossAt'
        ]);
    }

    function validTttJoinUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.keys().hasOnly(tttRoomFields())
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.hostName == resource.data.hostName
        && request.resource.data.createdAt == resource.data.createdAt
        && validTttBoard(request.resource.data.board)
        && changed.hasOnly([
          'xUid',
          'xName',
          'oUid',
          'oName',
          'playerScores',
          'status',
          'updatedAt'
        ])
        && (
          (resource.data.xUid == '' && request.resource.data.xUid == request.auth.uid && request.resource.data.oUid == resource.data.oUid)
          || (resource.data.oUid == '' && request.resource.data.oUid == request.auth.uid && request.resource.data.xUid == resource.data.xUid)
          || (resource.data.xUid == request.auth.uid && request.resource.data.xUid == resource.data.xUid)
          || (resource.data.oUid == request.auth.uid && request.resource.data.oUid == resource.data.oUid)
        );
    }

    function validTttHostUpdate() {
      return request.resource.data.keys().hasOnly(tttRoomFields())
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.createdAt == resource.data.createdAt
        && validTttBoard(request.resource.data.board);
    }

    function craftRoomFields() {
      return [
        'roomId',
        'ownerUid',
        'ownerName',
        'status',
        'updatedAt',
        'workspaceNodes',
        'elements',
        'participants',
        'leader',
        'lastCraftedName',
        'lastCraftedBy',
        'lastCraftedByName',
        'lastCraftedAt'
      ];
    }

    function validCraftRoomCreate(roomId) {
      return request.resource.data.keys().hasOnly(craftRoomFields())
        && request.resource.data.roomId == roomId
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerName is string
        && request.resource.data.status == 'waiting'
        && request.resource.data.updatedAt is number
        && request.resource.data.workspaceNodes is list
        && request.resource.data.elements is map
        && request.resource.data.participants is map
        && request.resource.data.participants.keys().hasOnly([request.auth.uid])
        && request.resource.data.leader == request.auth.uid;
    }

    function craftIsParticipant() {
      return resource.data.participants.keys().hasAny([request.auth.uid]);
    }

    function validCraftRoomUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let participantChanged = request.resource.data.participants.diff(resource.data.participants).affectedKeys();
      return request.resource.data.keys().hasOnly(craftRoomFields())
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.ownerName == resource.data.ownerName
        && request.resource.data.leader == resource.data.leader
        && request.resource.data.participants.keys().hasAll(resource.data.participants.keys())
        && request.resource.data.participants.keys().size() <= 5
        && participantChanged.hasOnly([request.auth.uid])
        && changed.hasOnly([
          'status',
          'updatedAt',
          'workspaceNodes',
          'elements',
          'participants',
          'lastCraftedName',
          'lastCraftedBy',
          'lastCraftedByName',
          'lastCraftedAt'
        ])
        && (
          craftIsParticipant()
          || (
            !resource.data.participants.keys().hasAny([request.auth.uid])
            && request.resource.data.participants.keys().hasAny([request.auth.uid])
          )
        );
    }

    function battleshipRoomFields() {
      return [
        'hostUid',
        'hostName',
        'guestUid',
        'guestName',
        'phase',
        'turnUid',
        'turnDeadlineAt',
        'placementDeadlineAt',
        'winnerUid',
        'winnerName',
        'boards',
        'eventLog',
        'createdAt',
        'updatedAt'
      ];
    }

    function connect4RoomFields() {
      return [
        'roomId',
        'status',
        'board',
        'turn',
        'winner',
        'winLine',
        'hostUid',
        'hostName',
        'guestUid',
        'guestName',
        'redUid',
        'redName',
        'yellowUid',
        'yellowName',
        'playerScores',
        'draws',
        'roundNumber',
        'scoreRound',
        'rematchVotes',
        'lastMoveColumn',
        'lastMoveIndex',
        'createdAt',
        'updatedAt',
        'coinTossAt'
      ];
    }

    function chopsticksRoomFields() {
      return [
        'roomId',
        'status',
        'hostUid',
        'hostName',
        'guestUid',
        'guestName',
        'hostLeft',
        'hostRight',
        'guestLeft',
        'guestRight',
        'turnUid',
        'turnSide',
        'winnerUid',
        'winnerName',
        'winnerSide',
        'playerScores',
        'roundNumber',
        'scoreRound',
        'rematchVotes',
        'lastAction',
        'lastActionType',
        'lastActorUid',
        'turnStartedAt',
        'turnDeadlineAt',
        'createdAt',
        'updatedAt'
      ];
    }

    function validConnect4Board(board) {
      return board is list
        && board.size() == 42;
    }

    function validChopsticksHand(value) {
      return value is int
        && value >= 0
        && value <= 4;
    }

    function validChopsticksRoomShape() {
      return validChopsticksHand(request.resource.data.hostLeft)
        && validChopsticksHand(request.resource.data.hostRight)
        && validChopsticksHand(request.resource.data.guestLeft)
        && validChopsticksHand(request.resource.data.guestRight)
        && request.resource.data.status is string
        && request.resource.data.hostUid is string
        && request.resource.data.hostName is string
        && request.resource.data.guestUid is string
        && request.resource.data.guestName is string
        && request.resource.data.turnUid is string
        && request.resource.data.turnSide is string
        && request.resource.data.winnerUid is string
        && request.resource.data.winnerName is string
        && request.resource.data.winnerSide is string
        && request.resource.data.playerScores is map
        && request.resource.data.roundNumber is int
        && request.resource.data.scoreRound is int
        && request.resource.data.rematchVotes is map
        && request.resource.data.lastAction is string
        && request.resource.data.lastActionType is string
        && request.resource.data.lastActorUid is string
        && request.resource.data.turnStartedAt is int
        && request.resource.data.turnDeadlineAt is int
        && request.resource.data.createdAt is int
        && request.resource.data.updatedAt is int;
    }

    function validConnect4RoomCreate(roomId) {
      return request.resource.data.keys().hasOnly(connect4RoomFields())
        && request.resource.data.roomId == roomId
        && request.resource.data.status == 'waiting'
        && validConnect4Board(request.resource.data.board)
        && request.resource.data.turn == 'R'
        && request.resource.data.winner == ''
        && request.resource.data.winLine is list
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.hostName is string
        && request.resource.data.guestUid == ''
        && request.resource.data.guestName is string
        && request.resource.data.redUid == request.auth.uid
        && request.resource.data.redName is string
        && request.resource.data.yellowUid == ''
        && request.resource.data.yellowName is string
        && request.resource.data.playerScores is map
        && request.resource.data.draws is int
        && request.resource.data.roundNumber is int
        && request.resource.data.scoreRound is int
        && request.resource.data.rematchVotes is map
        && request.resource.data.lastMoveColumn is int
        && request.resource.data.lastMoveIndex is int;
    }

    function connect4IsParticipant() {
      return resource.data.hostUid == request.auth.uid || resource.data.guestUid == request.auth.uid;
    }

    function connect4IsJoiner() {
      return resource.data.guestUid == '' && request.resource.data.guestUid == request.auth.uid;
    }

    function validConnect4ParticipantUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.keys().hasOnly(connect4RoomFields())
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.createdAt == resource.data.createdAt
        && validConnect4Board(request.resource.data.board)
        && changed.hasOnly([
          'status',
          'board',
          'turn',
          'winner',
          'winLine',
          'hostName',
          'guestName',
          'redUid',
          'redName',
          'yellowUid',
          'yellowName',
          'playerScores',
          'draws',
          'roundNumber',
          'scoreRound',
          'rematchVotes',
          'lastMoveColumn',
          'lastMoveIndex',
          'updatedAt',
          'coinTossAt'
        ]);
    }

    function validConnect4JoinUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.keys().hasOnly(connect4RoomFields())
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.hostName == resource.data.hostName
        && request.resource.data.createdAt == resource.data.createdAt
        && validConnect4Board(request.resource.data.board)
        && changed.hasOnly([
          'guestUid',
          'guestName',
          'playerScores',
          'status',
          'updatedAt'
        ])
        && resource.data.guestUid == ''
        && request.resource.data.guestUid == request.auth.uid;
    }

    function validChopsticksRoomCreate(roomId) {
      return request.resource.data.keys().hasOnly(chopsticksRoomFields())
        && request.resource.data.roomId == roomId
        && request.resource.data.status == 'waiting'
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.guestUid == ''
        && request.resource.data.hostLeft == 1
        && request.resource.data.hostRight == 1
        && request.resource.data.guestLeft == 1
        && request.resource.data.guestRight == 1
        && request.resource.data.turnUid == request.auth.uid
        && request.resource.data.turnSide == 'host'
        && request.resource.data.winnerUid == ''
        && request.resource.data.winnerName == ''
        && request.resource.data.winnerSide == ''
        && validChopsticksRoomShape();
    }

    function chopsticksIsParticipant() {
      return resource.data.hostUid == request.auth.uid || resource.data.guestUid == request.auth.uid;
    }

    function chopsticksIsJoiner() {
      return resource.data.guestUid == '' && request.resource.data.guestUid == request.auth.uid;
    }

    function validChopsticksParticipantUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.keys().hasOnly(chopsticksRoomFields())
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.createdAt == resource.data.createdAt
        && validChopsticksRoomShape()
        && changed.hasOnly([
          'status',
          'hostName',
          'guestName',
          'hostLeft',
          'hostRight',
          'guestLeft',
          'guestRight',
          'turnUid',
          'turnSide',
          'winnerUid',
          'winnerName',
          'winnerSide',
          'playerScores',
          'roundNumber',
          'scoreRound',
          'rematchVotes',
          'lastAction',
          'lastActionType',
          'lastActorUid',
          'turnStartedAt',
          'turnDeadlineAt',
          'updatedAt'
        ]);
    }

    function validChopsticksJoinUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.keys().hasOnly(chopsticksRoomFields())
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.hostName == resource.data.hostName
        && request.resource.data.createdAt == resource.data.createdAt
        && validChopsticksRoomShape()
        && changed.hasOnly([
          'guestUid',
          'guestName',
          'playerScores',
          'status',
          'lastAction',
          'lastActionType',
          'updatedAt'
        ])
        && resource.data.guestUid == ''
        && request.resource.data.guestUid == request.auth.uid;
    }

    function validBattleshipRoomCreate() {
      return request.resource.data.keys().hasOnly(battleshipRoomFields())
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.hostName is string
        && request.resource.data.guestUid == ''
        && request.resource.data.guestName is string
        && request.resource.data.phase == 'lobby'
        && request.resource.data.turnUid == ''
        && request.resource.data.turnDeadlineAt is int
        && request.resource.data.placementDeadlineAt is int
        && request.resource.data.winnerUid == ''
        && request.resource.data.winnerName == ''
        && request.resource.data.boards is map
        && request.resource.data.boards.keys().hasOnly([request.auth.uid])
        && request.resource.data.eventLog is list;
    }

    function battleshipIsParticipant() {
      return resource.data.hostUid == request.auth.uid || resource.data.guestUid == request.auth.uid;
    }

    function battleshipIsJoiner() {
      return resource.data.guestUid == '' && request.resource.data.guestUid == request.auth.uid;
    }

    function validBattleshipParticipantUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.keys().hasOnly(battleshipRoomFields())
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.hostName == resource.data.hostName
        && request.resource.data.guestUid == resource.data.guestUid
        && request.resource.data.guestName == resource.data.guestName
        && request.resource.data.createdAt == resource.data.createdAt
        && changed.hasOnly([
          'phase',
          'turnUid',
          'turnDeadlineAt',
          'placementDeadlineAt',
          'winnerUid',
          'winnerName',
          'boards',
          'eventLog',
          'updatedAt'
        ]);
    }

    function validBattleshipJoinUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.keys().hasOnly(battleshipRoomFields())
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.hostName == resource.data.hostName
        && request.resource.data.createdAt == resource.data.createdAt
        && changed.hasOnly([
          'guestUid',
          'guestName',
          'phase',
          'placementDeadlineAt',
          'boards',
          'eventLog',
          'updatedAt'
        ])
        && resource.data.guestUid == ''
        && request.resource.data.guestUid == request.auth.uid;
    }

    match /displayNames/{normalized} {
      allow read: if true;
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/displayNames/$(normalized))
        && validDisplayNameReservationDoc(normalized);
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.normalized == resource.data.normalized
        && validDisplayNameReservationDoc(normalized);
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /userProfiles/{uid} {
      allow read: if true;
      allow create: if (isOwner(uid) || isTrustedOwner())
        && validUserProfileDoc(uid)
        && (isTrustedOwner() || selfProfileSignupCaptchaAbsentOnCreate())
        && (isTrustedOwner() || selfProfileRolesAllowed());
      allow update: if validUserProfileDoc(uid) && (
        (
          isOwner(uid)
          && resource.data.uid == request.auth.uid
          && selfProfileModerationUnchanged()
          && selfProfileSignupCaptchaUnchanged()
          && selfProfileRolesAllowed()
        )
        || isTrustedOwner()
        || supportWarningOnlyUpdate()
        || moderatorModerationUpdate()
        || adminModerationUpdate()
        || staffRoleUpdateAllowed()
      );
      allow delete: if isOwner(uid) || isTrustedOwner();
    }

    match /captchaVerifications/{verificationId} {
      allow read, write: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (
          resource.data.senderUid == request.auth.uid
          || resource.data.recipientUid == request.auth.uid
        );
      allow create: if signedIn()
        && validFriendRequestDoc();
      allow update: if signedIn()
        && validFriendRequestUpdate();
      allow delete: if signedIn()
        && (
          resource.data.senderUid == request.auth.uid
          || resource.data.recipientUid == request.auth.uid
          || isTrustedOwner()
        );
    }

    match /friendships/{friendshipId} {
      allow read: if signedIn()
        && resource.data.participants is list
        && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if signedIn()
        && validFriendshipDoc();
      allow update: if signedIn()
        && resource.data.participants is list
        && resource.data.participants.hasAny([request.auth.uid])
        && request.resource.data.participants == resource.data.participants;
      allow delete: if signedIn()
        && resource.data.participants is list
        && (
          resource.data.participants.hasAny([request.auth.uid])
          || isTrustedOwner()
        );
    }

    match /tttRooms/{roomId} {
      allow read: if signedIn() && validTttRoomId(roomId);
      allow create: if signedIn() && validTttRoomId(roomId) && validTttRoomCreate(roomId);
      allow update: if signedIn() && validTttRoomId(roomId) && (
        (isTrustedOwner() && validTttHostUpdate())
        || (resource.data.hostUid == request.auth.uid && validTttHostUpdate())
        || (tttIsCurrentPlayer() && validTttParticipantUpdate())
        || (tttIsJoiningPlayer() && validTttJoinUpdate())
      );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && validTttRoomId(roomId);
        allow create: if signedIn() && validTttRoomId(roomId) && validTttMessage();
        allow update, delete: if false;
      }
    }

    match /craftRooms/{roomId} {
      allow read: if signedIn() && validCraftRoomId(roomId);
      allow create: if signedIn() && validCraftRoomId(roomId) && validCraftRoomCreate(roomId);
      allow update: if signedIn() && validCraftRoomId(roomId) && validCraftRoomUpdate();
      allow delete: if false;

      match /presence/{uid} {
        allow read: if signedIn() && validCraftRoomId(roomId);
        allow create, update: if signedIn() && validCraftRoomId(roomId) && request.auth.uid == uid && validPresenceDoc();
        allow delete: if signedIn() && validCraftRoomId(roomId) && request.auth.uid == uid;
      }
    }

    match /battleshipRooms/{roomId} {
      allow read: if signedIn() && validBattleshipRoomId(roomId);
      allow create: if signedIn() && validBattleshipRoomId(roomId) && validBattleshipRoomCreate();
      allow update: if signedIn() && validBattleshipRoomId(roomId) && (
        (isTrustedOwner() && request.resource.data.keys().hasOnly(battleshipRoomFields()))
        || (battleshipIsParticipant() && validBattleshipParticipantUpdate())
        || (battleshipIsJoiner() && validBattleshipJoinUpdate())
      );
      allow delete: if false;

      match /presence/{uid} {
        allow read: if signedIn() && validBattleshipRoomId(roomId);
        allow create, update: if signedIn() && validBattleshipRoomId(roomId) && request.auth.uid == uid && validPresenceDoc();
        allow delete: if signedIn() && validBattleshipRoomId(roomId) && request.auth.uid == uid;
      }

      match /messages/{messageId} {
        allow read: if signedIn() && validBattleshipRoomId(roomId);
        allow create: if signedIn()
          && validBattleshipRoomId(roomId)
          && request.resource.data.keys().hasOnly(['uid', 'text', 'createdAt'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 220;
        allow update, delete: if false;
      }
    }

    match /connect4Rooms/{roomId} {
      allow read: if signedIn() && validConnect4RoomId(roomId);
      allow create: if signedIn() && validConnect4RoomId(roomId) && validConnect4RoomCreate(roomId);
      allow update: if signedIn() && validConnect4RoomId(roomId) && (
        connect4IsParticipant() && validConnect4ParticipantUpdate()
        || connect4IsJoiner() && validConnect4JoinUpdate()
      );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && validConnect4RoomId(roomId);
        allow create: if signedIn() && validConnect4RoomId(roomId) && validConnect4Message();
        allow update, delete: if false;
      }
    }

    match /chopsticksRooms/{roomId} {
      allow read: if signedIn() && validChopsticksRoomId(roomId);
      allow create: if signedIn() && validChopsticksRoomId(roomId) && validChopsticksRoomCreate(roomId);
      allow update: if signedIn() && validChopsticksRoomId(roomId) && (
        chopsticksIsParticipant() && validChopsticksParticipantUpdate()
        || chopsticksIsJoiner() && validChopsticksJoinUpdate()
      );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && validChopsticksRoomId(roomId);
        allow create: if signedIn() && validChopsticksRoomId(roomId) && validConnect4Message();
        allow update, delete: if false;
      }
    }
  }
}
